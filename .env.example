# Absolute path to the repository root
REPO_ROOT=/path/to/alzheimer-peptide-design

# Optional local MLflow tracking URI
MLFLOW_TRACKING_URI=sqlite:///packages/bbb_models/mlflow.db

# Keep uv virtual environment at repo root
UV_PROJECT_ENVIRONMENT=.venv

# Boltz API key for peptide folding (https://api.boltz.bio/docs/)
BOLTZ_API_KEY=
